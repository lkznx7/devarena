# =============================================================================
# DevArena Environment Variables Example
# =============================================================================
# Copy this to .env and fill in your values
# NEVER commit .env with real secrets to git
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================
DB_URL=jdbc:postgresql://localhost:5432/devarena
DB_USER=postgres
DB_PASSWORD=your-secure-password-here

# =============================================================================
# APPLICATION
# =============================================================================
APP_PORT=8080
NODE_ENV=development

# =============================================================================
# JWT - GENERATE A SECURE KEY FOR PRODUCTION
# =============================================================================
# Use: openssl rand -base64 32
JWT_SECRET=CHANGE-THIS-TO-A-SECURE-256-BIT-KEY-FOR-PRODUCTION

# =============================================================================
# OAUTH2 (FUTURE)
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# EXTERNAL APIs
# =============================================================================
PISTON_API_URL=https://emkc.org/api/v2/piston
GROQ_API_KEY=your-groq-api-key

# =============================================================================
# FRONTEND
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8080/api