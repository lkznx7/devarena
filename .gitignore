# =============================================================================
# DevArena - Git Ignore Configuration
# =============================================================================

# =============================================================================
# NODE / NPM
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
package-lock.json
yarn.lock

# Build outputs
.next/
out/
dist/
build/
.nuxt/
.cache/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# =============================================================================
# JAVA / MAVEN / GRADLE
# =============================================================================
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# Compiled class files
*.class

# Log files
*.log

# Package files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Virtual machine crash logs
hs_err_pid*
replay_pid*

# Maven
.mvn/
mvnw
mvnw.cmd

# Gradle
.gradle/
gradle/
gradlew
gradlew.bat

# =============================================================================
# DOCKER
# =============================================================================
.dockerignore
Dockerfile
docker-compose.override.yml

# =============================================================================
# DATABASES
# =============================================================================
*.sql
*.db
*.sqlite

# =============================================================================
# TESTING
# =============================================================================
coverage/
.nyc_output/
test-results/
playwright-report/

# =============================================================================
# SECRETS & KEYS
# =============================================================================
*.pem
*.key
*.crt
*.p12
secrets/
credentials.json
service-account.json

# =============================================================================
# DOCUMENTATION GENERATED FILES
# =============================================================================
docs/.vitepress/dist/
docs/.vitepress/cache/

# =============================================================================
# TEMP FILES
# =============================================================================
tmp/
temp/
*.tmp
*.temp
*.bak
*.orig

# =============================================================================
# CREDENTIALS - NEVER COMMIT
# =============================================================================
credentials/
.env.local
.env.*.local
*.env.local